{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC",
      "description": "Configure with Ninja using cl/link from VsDev environment.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "FAUST_INCLUDE_DIR": "E:/Program Files/Faust/include",
        "YC20_LV2_BUNDLE_DIR": "$env{USERPROFILE}/.lv2/foo-yc20.lv2"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "inherits": "windows-msvc",
      "binaryDir": "${sourceDir}/build-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release Build",
      "configurePreset": "windows-msvc",
      "targets": [
        "all"
      ]
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug Build",
      "configurePreset": "windows-msvc-debug",
      "targets": [
        "all"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release Tests",
      "configurePreset": "windows-msvc",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
